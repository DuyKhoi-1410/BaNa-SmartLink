PORT=3636
DB_CONNECTION_STRING=postgresql://user:password@host:5432/database

JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES=30m
JWT_REFRESH_EXPIRES=7d
# Giu JWT_EXPIRES_IN cho tuong thich, khong con dung truc tiep
JWT_EXPIRES_IN=7d

# Mat khau mac dinh khi seed (se duoc hash bcrypt truoc khi luu DB)
SEED_MAT_KHAU_XA=demo123
SEED_MAT_KHAU_THON_PREFIX=demo
SEED_MAT_KHAU_DAN=danmat1

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# CF Access cho Supabase Storage (upload minh chung / avatar)
CF-Access-Client-Id=your-cf-access-client-id
CF-Access-Client-Secret=your-cf-access-client-secret


# ===== RAG / Chatbot (Ollama) =====
# Tam thoi dung Ollama tren may local. Sau doi sang tunnel: chi sua RAG_BASE_URL + dien 2 ma CF ben duoi.
# Model va so chieu show that de doi chieu (khong nhay cam). Vector bge-m3 = 1024 chieu.
RAG_BASE_URL=http://localhost:11434
RAG_CHAT_MODEL=qwen3:8b
RAG_EMBEDDING_MODEL=bge-m3
RAG_EMBEDDING_DIM=1024

# CF Access cho RAG (de trong khi goi localhost; dien khi goi qua Cloudflare tunnel)
RAG_CF_ACCESS_CLIENT_ID=your-cf-access-client-id
RAG_CF_ACCESS_CLIENT_SECRET=your-cf-access-client-secret
